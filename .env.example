# Copy this file to .env and fill in your values

# Twitch app credentials
CLIENT_ID=

# OAuth token for the bot Twitch account (prefix with "oauth:")
OAUTH_TOKEN=

# Numeric Twitch user ID of the bot account
BOT_USER_ID=

# YOUR Twitch channel's numeric user ID
# Look yours up at: https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/
CHAT_CHANNEL_USER_ID=

# Firebase
FIREBASE_PROJECT_ID=hydro-pogo-raids
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
