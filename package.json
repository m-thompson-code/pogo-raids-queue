{
  "name": "@pogo-raid-system/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "npx nx build twitch-bot --output-style=stream && node --env-file=.env apps/twitch-bot/dist/main.js",
    "dev": "tsx watch --env-file=.env apps/twitch-bot/src/main.ts",
    "test": "tsx --test apps/twitch-bot/src/**/*.test.ts libs/firebase/src/**/*.test.ts",
    "serve": "npx nx serve client",
    "deploy": "npx nx build client --configuration=production && npx firebase deploy --only hosting"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "^22.7.5",
    "@nx/esbuild": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/node": "^22.7.5",
    "@nx/vite": "^22.7.5",
    "@nx/web": "22.7.5",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "^4.1.8",
    "angular-eslint": "^21.2.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "nx": "22.7.5",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "libs/*"
  ],
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "rxjs": "~7.8.0",
    "ws": "^8.21.0"
  }
}
